// ============================================================
// Next.js + Auth.js (NextAuth v5) — Prisma Schema
// Covers: exact Auth.js adapter schema, @db.Text, @db.VarChar,
// @db.Char, @db.Decimal, Bytes scalar, Unsupported("text[]"),
// @@schema (multi-schema), @default(dbgenerated(...)),
// @@ignore (legacy model), @@fulltext (previewFeature).
// ============================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema", "fullTextSearch", "fullTextIndex"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["auth", "public"]
}

// ── Auth.js required models (exact adapter schema) ────────────

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
  @@schema("auth")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
  @@schema("auth")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
  @@schema("auth")
}

// ── User (Auth.js base + app extensions) ─────────────────────

enum UserRole {
  USER
  MODERATOR
  ADMIN
  SUPER_ADMIN

  @@schema("auth")
}

enum UserPlan {
  FREE
  PRO
  TEAM
  ENTERPRISE

  @@schema("auth")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime? @map("email_verified")
  image         String?

  // App-level extensions
  role          UserRole  @default(USER)
  plan          UserPlan  @default(FREE)
  bio           String?   @db.Text
  website       String?
  twitterHandle String?   @map("twitter_handle")
  githubHandle  String?   @map("github_handle")
  stripeCustomerId String? @unique @map("stripe_customer_id")
  metadata      Json?
  deletedAt     DateTime? @map("deleted_at")

  createdAt     DateTime  @default(dbgenerated("now()")) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  accounts      Account[]
  sessions      Session[]
  profile       Profile?
  posts         Post[]
  comments      Comment[]
  notifications Notification[]
  media         Media[]

  @@map("users")
  @@schema("auth")
}

// ── App models (public schema) ────────────────────────────────

model Profile {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String  @unique @map("user_id")
  displayName String  @map("display_name") @db.VarChar(100)
  bio         String? @db.Text
  avatarData  Bytes?  @map("avatar_data")  // small inline avatar (thumbnail)
  avatarUrl   String? @map("avatar_url")
  coverUrl    String? @map("cover_url")
  location    String? @db.VarChar(200)
  tagline     String? @db.VarChar(300)
  socialLinks Json?   @map("social_links")

  // PostgreSQL text[] — Unsupported because Prisma has no native array string
  interests   Unsupported("text[]")? @map("interests")

  followerCount  Int @default(0) @map("follower_count")
  followingCount Int @default(0) @map("following_count")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
  @@schema("public")
}

enum PostStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
  DELETED

  @@schema("public")
}

model Category {
  id          Int      @id @default(autoincrement())
  parentId    Int?     @map("parent_id")
  name        String   @db.VarChar(200)
  slug        String   @unique @db.VarChar(200)
  description String?  @db.Text
  imageUrl    String?  @map("image_url")
  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")

  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[] @relation("CategoryTree")
  posts    Post[]

  @@map("categories")
  @@schema("public")
}

model Tag {
  id        Int      @id @default(autoincrement())
  name      String   @unique @db.VarChar(100)
  slug      String   @unique @db.VarChar(100)
  postCount Int      @default(0) @map("post_count")
  createdAt DateTime @default(now()) @map("created_at")

  posts PostTag[]

  @@map("tags")
  @@schema("public")
}

model Post {
  id          String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  authorId    String     @map("author_id")
  categoryId  Int?       @map("category_id")
  status      PostStatus @default(DRAFT)
  title       String     @db.VarChar(500)
  slug        String     @db.VarChar(500)
  excerpt     String?    @db.Text
  body        String     @db.Text
  coverUrl    String?    @map("cover_url")
  readingTime Int?       @map("reading_time")
  viewCount   BigInt     @default(0) @map("view_count")
  likeCount   Int        @default(0) @map("like_count")
  commentCount Int       @default(0) @map("comment_count")
  isPinned    Boolean    @default(false) @map("is_pinned")
  isFeatured  Boolean    @default(false) @map("is_featured")
  metadata    Json?
  publishedAt DateTime?  @map("published_at")
  deletedAt   DateTime?  @map("deleted_at")
  createdAt   DateTime   @default(dbgenerated("now()")) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  author   User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  category Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  tags     PostTag[]
  comments Comment[]
  media    Media[]

  @@unique([authorId, slug])
  @@index([status, publishedAt(sort: Desc)])
  @@index([categoryId])
  // MySQL only (previewFeature): @@fulltext([title, body])
  @@map("posts")
  @@schema("public")
}

model PostTag {
  postId    String   @map("post_id") @db.Uuid
  tagId     Int      @map("tag_id")
  createdAt DateTime @default(now()) @map("created_at")

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
  @@map("post_tags")
  @@schema("public")
}

model Comment {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  postId    String    @map("post_id") @db.Uuid
  authorId  String    @map("author_id")
  parentId  String?   @map("parent_id") @db.Uuid
  body      String    @db.Text
  likeCount Int       @default(0) @map("like_count")
  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime  @default(dbgenerated("now()")) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  post     Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  author   User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent   Comment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies  Comment[] @relation("CommentReplies")

  @@index([postId, createdAt(sort: Desc)])
  @@map("comments")
  @@schema("public")
}

model Media {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String   @map("user_id")
  postId     String?  @map("post_id") @db.Uuid
  filename   String   @db.VarChar(500)
  mimeType   String   @map("mime_type") @db.VarChar(100)
  sizeBytes  BigInt   @map("size_bytes")
  url        String
  thumbnail  Bytes?   // small inline thumbnail
  width      Int?
  height     Int?
  alt        String?  @db.VarChar(500)
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post? @relation(fields: [postId], references: [id], onDelete: SetNull)

  @@map("media")
  @@schema("public")
}

enum NotificationType {
  COMMENT
  LIKE
  FOLLOW
  MENTION
  SYSTEM
  MARKETING

  @@schema("public")
}

model Notification {
  id           String           @id @default(cuid())
  userId       String           @map("user_id")
  type         NotificationType
  title        String           @db.VarChar(500)
  body         String?          @db.Text
  actionUrl    String?          @map("action_url")
  imageUrl     String?          @map("image_url")
  metadata     Json?
  isRead       Boolean          @default(false) @map("is_read")
  readAt       DateTime?        @map("read_at")
  createdAt    DateTime         @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt(sort: Desc)])
  @@map("notifications")
  @@schema("public")
}

// ── Legacy model — kept for migration reference, ignored by Prisma client ──
model LegacyPost {
  id      Int    @id @default(autoincrement())
  title   String
  content String @db.Text

  @@ignore
  @@map("legacy_posts")
  @@schema("public")
}
